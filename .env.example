# Google API Key for Gemini LLM and Text Embeddings
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL
# Defaults to local SQLite if left blank: sqlite:///./admissions_chatbot.db
# For MySQL: mysql+pymysql://user:password@host:port/dbname
# For Supabase/PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./admissions_chatbot.db

# Redis Connection URL (Upstash or local Redis)
# Leave blank to use in-memory database fallback (session history will be lost on restart)
# Example: rediss://default:your_password@your_endpoint.upstash.io:6379
REDIS_URL=

# Directory to store local ChromaDB vectors
CHROMA_DB_DIR=./chroma_db
